{
  "expo": {
    "name": "easy-pgt",
    "slug": "easypgt",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "easypgt",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSBluetoothAlwaysUsageDescription": "EasyPGT uses Bluetooth to discover and connect to nearby peers for proximity handshakes.",
        "NSBluetoothPeripheralUsageDescription": "EasyPGT uses Bluetooth to exchange signed session data with nearby peers.",
        "NFCReaderUsageDescription": "EasyPGT uses NFC to bootstrap authenticated proximity sessions."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.jack.v.curtis.easypgt",
      "permissions": [
        "android.permission.BLUETOOTH_SCAN",
        "android.permission.BLUETOOTH_CONNECT",
        "android.permission.BLUETOOTH_ADVERTISE",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.NFC",
        "android.permission.BLUETOOTH",
        "android.permission.BLUETOOTH_ADMIN",
        "android.permission.ACCESS_COARSE_LOCATION"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      [
        "expo-secure-store",
        {
          "faceIDPermission": "EasyPGT uses secure storage to protect identity keys behind device authentication."
        }
      ],
      [
        "react-native-nfc-manager",
        {
          "nfcPermission": "EasyPGT uses NFC to bootstrap authenticated proximity sessions.",
          "includeNdefEntitlement": true
        }
      ],
      [
        "react-native-ble-plx",
        {
          "isBackgroundEnabled": true,
          "modes": [
            "central",
            "peripheral"
          ],
          "bluetoothAlwaysPermission": "EasyPGT uses Bluetooth to discover and connect to nearby peers for proximity handshakes."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "a486d059-e2f4-4770-9900-8a5c66961613"
      }
    },
    "owner": "jack.v.curtis"
  }
}
